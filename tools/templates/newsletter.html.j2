<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ headline }}</title>
<style>
  /* Base — reset */
  body, table, td, a { -webkit-text-size-adjust: 100%; -ms-text-size-adjust: 100%; }
  table, td { mso-table-lspace: 0pt; mso-table-rspace: 0pt; }
  img { -ms-interpolation-mode: bicubic; border: 0; outline: none; text-decoration: none; display: block; }

  body {
    margin: 0; padding: 0;
    background-color: #F0F4F8;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
    color: #1C1C1C;
  }

  /* Wrapper */
  .wrapper {
    width: 100%; background-color: #F0F4F8;
  }
  .container {
    max-width: 640px; margin: 0 auto; background-color: #ffffff;
  }

  /* Header */
  .header {
    background-color: #1A3C5E;
    padding: 32px 40px 28px 40px;
  }
  .header-label {
    font-size: 11px; font-weight: 700; letter-spacing: 2px;
    color: #F6AE2D; text-transform: uppercase; margin: 0 0 10px 0;
  }
  .header h1 {
    margin: 0 0 10px 0;
    font-size: 26px; font-weight: 800; line-height: 1.2;
    color: #ffffff;
  }
  .header .subheadline {
    margin: 0;
    font-size: 15px; line-height: 1.5; color: #B8CDE0;
  }
  .header-meta {
    margin-top: 20px;
    font-size: 12px; color: #6B97BA;
  }

  /* Hero stat strip */
  .stat-strip {
    background-color: #2E86AB; padding: 0;
  }
  .stat-strip table { width: 100%; }
  .stat-cell {
    padding: 18px 12px; text-align: center;
    border-right: 1px solid rgba(255,255,255,0.15);
  }
  .stat-cell:last-child { border-right: none; }
  .stat-value {
    display: block; font-size: 28px; font-weight: 800;
    color: #F6AE2D; line-height: 1;
  }
  .stat-label {
    display: block; font-size: 10px; color: rgba(255,255,255,0.75);
    margin-top: 4px; line-height: 1.3;
  }

  /* Body content */
  .body-content { padding: 32px 40px; }

  /* Sections */
  .section { margin-bottom: 32px; padding-bottom: 32px; border-bottom: 1px solid #E5EAF0; }
  .section:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
  .section h2 {
    margin: 0 0 14px 0;
    font-size: 18px; font-weight: 700;
    color: #1A3C5E; line-height: 1.3;
  }
  .section p {
    margin: 0 0 14px 0;
    font-size: 15px; line-height: 1.7; color: #3A3A3A;
  }
  .section p:last-child { margin-bottom: 0; }

  /* Stat callout block */
  .stat-callout {
    margin: 18px 0 0 0;
    padding: 14px 18px;
    background-color: #F4F7FA;
    border-left: 4px solid #F6AE2D;
    font-size: 14px; font-weight: 600;
    color: #1A3C5E; line-height: 1.4;
  }

  /* Chart image */
  .chart-block {
    margin: 24px 0 0 0;
  }
  .chart-block img {
    width: 100%; max-width: 560px;
    border-radius: 6px;
  }

  /* Key insight box */
  .insight-box {
    margin: 32px 0;
    background-color: #1A3C5E;
    border-radius: 6px;
    padding: 24px 28px;
  }
  .insight-box .insight-label {
    font-size: 10px; font-weight: 700; letter-spacing: 2px;
    color: #F6AE2D; text-transform: uppercase; margin: 0 0 10px 0;
  }
  .insight-box p {
    margin: 0;
    font-size: 16px; line-height: 1.6; color: #EAF1F8;
    font-style: italic;
  }

  /* CTA footer */
  .cta-block {
    margin-top: 32px;
    padding: 24px 28px;
    background-color: #F4F7FA;
    border-radius: 6px;
    border: 1px solid #DDE5EE;
  }
  .cta-block p {
    margin: 0;
    font-size: 14px; line-height: 1.6; color: #3A3A3A;
  }

  /* Footer */
  .footer {
    background-color: #1A3C5E;
    padding: 24px 40px;
    text-align: center;
  }
  .footer p {
    margin: 0;
    font-size: 12px; color: #6B97BA; line-height: 1.6;
  }
  .footer a { color: #F6AE2D; text-decoration: none; }
</style>
</head>
<body>
<div class="wrapper">
<table class="container" cellpadding="0" cellspacing="0" border="0" width="640" align="center">

  <!-- HEADER -->
  <tr>
    <td class="header">
      <p class="header-label">Newsletter</p>
      <h1>{{ headline }}</h1>
      <p class="subheadline">{{ subheadline }}</p>
      <p class="header-meta">{{ date }}</p>
    </td>
  </tr>

  <!-- STAT STRIP -->
  {% if key_stats %}
  <tr>
    <td class="stat-strip">
      <table cellpadding="0" cellspacing="0" border="0">
        <tr>
          {% for stat in key_stats[:3] %}
          <td class="stat-cell" width="{{ (100 / [key_stats|length, 3]|min)|int }}%">
            <span class="stat-value">{{ stat.value }}{{ stat.unit }}</span>
            <span class="stat-label">{{ stat.label }}</span>
          </td>
          {% endfor %}
        </tr>
      </table>
    </td>
  </tr>
  {% endif %}

  <!-- BODY CONTENT -->
  <tr>
    <td class="body-content">

      <!-- BAR CHART (all stats) -->
      {% if bar_chart_b64 %}
      <div class="chart-block">
        <img src="data:image/png;base64,{{ bar_chart_b64 }}" alt="Key statistics chart" width="560">
      </div>
      {% endif %}

      <!-- SECTIONS -->
      {% for section in sections %}
      <div class="section" style="margin-top: {% if loop.first %}32px{% else %}0{% endif %};">
        <h2>{{ section.title }}</h2>
        {% for para in section.body.split('\n\n') %}
        <p>{{ para }}</p>
        {% endfor %}
        {% if section.stat_callout %}
        <div class="stat-callout">{{ section.stat_callout }}</div>
        {% endif %}
        {% if loop.index <= stat_cards_b64|length %}
        <div class="chart-block" style="margin-top: 16px;">
          <img src="data:image/png;base64,{{ stat_cards_b64[loop.index - 1] }}" alt="Stat card" width="560">
        </div>
        {% endif %}
      </div>
      {% endfor %}

      <!-- KEY INSIGHT -->
      <div class="insight-box">
        <p class="insight-label">Key Insight</p>
        <p>{{ key_insight }}</p>
      </div>

      <!-- CTA -->
      <div class="cta-block">
        <p>{{ cta }}</p>
      </div>

    </td>
  </tr>

  <!-- FOOTER -->
  <tr>
    <td class="footer">
      <p>You're receiving this newsletter because you subscribed.<br>
      Questions or feedback? Reply to this email.</p>
    </td>
  </tr>

</table>
</div>
</body>
</html>
